<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ejemplo_Maui_ReproBatch.Pages.MainPage">

	<Grid>
		<RefreshView x:Name="refreshView"  IsRefreshing="{Binding IsRefreshing}" IsEnabled="True" Refreshing="OnRefreshViewRefreshing">
			<WebView x:Name="webView" Navigating="WebView_Navigating" Navigated="WebView_Navigated"/>
		</RefreshView>
	</Grid>
</ContentPage>
